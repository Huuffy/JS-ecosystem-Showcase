{
  "name": "mern-stack-multi-tenant-support",
  "version": "1.0.0",
  "description": "Multi-Tenant SaaS Customer Support Platform built with MERN Stack",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon backend/server.js",
    "client": "cd frontend && npm start",
    "build": "cd frontend && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint backend frontend/src",
    "lint:fix": "eslint backend frontend/src --fix",
    "seed": "node backend/scripts/seedData.js",
    "deploy": "npm run build && npm run start"
  },
  "keywords": [
    "mern",
    "mongodb",
    "express",
    "react",
    "nodejs",
    "multi-tenant",
    "saas",
    "support-platform",
    "customer-service",
    "ai-chatbot",
    "real-time",
    "websockets"
  ],
  "author": "MERN Stack Developer",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.2",
    "multer": "^1.4.5-lts.1",
    "multer-gridfs-storage": "^5.0.2",
    "gridfs-stream": "^1.1.1",
    "bull": "^4.11.3",
    "redis": "^4.6.8",
    "nodemailer": "^6.9.4",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "joi": "^17.9.2",
    "sharp": "^0.32.5",
    "pdf2pic": "^3.0.1",
    "node-cron": "^3.0.2",
    "web3": "^4.1.1",
    "bitcoinjs-lib": "^6.1.3",
    "axios": "^1.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0",
    "jest": "^29.6.4",
    "supertest": "^6.3.3",
    "eslint": "^8.47.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "@babel/core": "^7.22.10",
    "@babel/preset-env": "^7.22.10",
    "@babel/preset-react": "^7.22.5"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/mern-stack-multi-tenant-support.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/mern-stack-multi-tenant-support/issues"
  },
  "homepage": "https://github.com/your-username/mern-stack-multi-tenant-support#readme"
}
